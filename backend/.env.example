# Weather Insight Dashboard - Backend Environment Variables
# Copy this file to .env and fill in your values

# OpenWeatherMap API Key
# Get a free key at: https://openweathermap.org/api
# Without a key, the app uses realistic mock data automatically
OPENWEATHERMAP_API_KEY= 
# Database URL (defaults to SQLite if not set)
# For PostgreSQL: postgresql://user:password@localhost/weatherdb
DATABASE_URL=sqlite:///./weather.db
